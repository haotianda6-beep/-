# Copy to .env and fill values locally. Never commit .env.

# Runtime safety switches
LIVE_DATA_ENABLED=true
TRADING_ENABLED=false
ORDER_EXECUTION_ENABLED=false
API_READ_ONLY_MODE=true
# Optional. If empty, server creates config/credentials.key locally.
CREDENTIALS_MASTER_KEY=
SERVER_PUBLIC_IP=

# Binance USD-M Futures
BINANCE_API_KEY=
BINANCE_API_SECRET=
BINANCE_USE_TESTNET=false

# OKX
OKX_API_KEY=
OKX_API_SECRET=
OKX_API_PASSPHRASE=
OKX_USE_DEMO=false

# Gate
GATE_API_KEY=
GATE_API_SECRET=
GATE_USE_TESTNET=false

# Bitget
BITGET_API_KEY=
BITGET_API_SECRET=
BITGET_API_PASSPHRASE=
BITGET_USE_DEMO=false

# Bybit
BYBIT_API_KEY=
BYBIT_API_SECRET=
BYBIT_USE_TESTNET=false

# AI monitor, optional. DeepSeek is OpenAI-compatible.
AI_PROVIDER=deepseek
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat
OPENAI_API_KEY=

# MT4 bridge. Set a random token and use the same value in the MT4 EA input.
MT4_BRIDGE_TOKEN=

# Alerts, optional
ALERT_WEBHOOK_URL=
